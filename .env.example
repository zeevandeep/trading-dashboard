# Zerodha Kite Connect credentials
# Get these from https://developers.kite.trade/apps
# IMPORTANT: Set redirect URL to http://127.0.0.1:5927/callback in your Kite app settings
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Environment: research | paper | live
TRADING_ENV=research

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
